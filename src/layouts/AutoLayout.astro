---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, ogImage = '/og/og-detailing.jpg', noindex } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage} lane="auto" noindex={noindex}>
  <slot />
</BaseLayout>
