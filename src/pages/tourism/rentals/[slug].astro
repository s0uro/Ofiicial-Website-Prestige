---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/primitives/Section.astro';
import Eyebrow from '../../../components/primitives/Eyebrow.astro';
import Card from '../../../components/primitives/Card.astro';
import Badge from '../../../components/primitives/Badge.astro';
import PriceTag from '../../../components/primitives/PriceTag.astro';
import { WhatsAppButton } from '../../../components/cta/WhatsAppButton';
import { rentalListingSchema, breadcrumbSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  const all = await getCollection('fleet');
  return all
    .filter((e) => e.data.listingType === 'rental')
    .map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'fleet'>;
}
const { entry } = Astro.props as Props;
const { Content } = await entry.render();
const d = entry.data;
if (d.listingType !== 'rental') throw new Error('Expected a rental listing');

const vehicle = `${d.year} ${d.make} ${d.model}${d.trim ? ' ' + d.trim : ''}`;
const seoTitle = `${d.year} ${d.make} ${d.model}`;
const metaDescription = `${vehicle} for rent in Pafos, Cyprus. From €${d.dailyRateFromEUR}/day, ${d.transmission} ${d.fuel}, ${d.seats} seats. Insurance included. Hotel delivery in Pafos district.`.slice(0, 158);
const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Rentals', url: '/tourism/rentals' },
  { name: vehicle, url: `/tourism/rentals/${entry.slug}` },
]);

const schemaImages = await Promise.all(
  d.images.slice(0, 3).map((img) =>
    getImage({ src: img, width: 1280, format: 'webp', quality: 78 })
  )
);
const schemaImageUrls = schemaImages.map((g) => g.src);
const schema = rentalListingSchema(entry, `/tourism/rentals/${entry.slug}`, schemaImageUrls);
---
<BaseLayout
  lane="tourism"
  title={seoTitle}
  description={metaDescription}
  ogImage="/og/og-tourism.jpg"
  jsonLd={schema ? [schema, breadcrumbs] : breadcrumbs}
>
  <Section>
    <Eyebrow>Tourism · Rental</Eyebrow>
    <h1 class="mt-3 font-display text-4xl text-fg md:text-6xl text-balance">{vehicle}</h1>
    <div class="mt-4 flex flex-wrap items-center gap-4">
      <PriceTag amount={d.dailyRateFromEUR} period="per-day" />
      {d.weeklyRateFromEUR && <PriceTag amount={d.weeklyRateFromEUR} period="per-week" variant="inline" />}
      {d.insuranceIncluded && <Badge variant="trust">Insurance included</Badge>}
      {d.available ? <Badge variant="gold">Available</Badge> : <Badge variant="muted">On hire</Badge>}
    </div>

    <div class="mt-10 grid gap-8 md:grid-cols-[1.4fr_1fr]">
      <div class="overflow-hidden rounded-lg border border-gold/10 bg-bg-elev p-1">
        <Image
          src={d.images[0]}
          alt={vehicle}
          width={1280}
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 60vw"
          format="webp"
          quality={78}
          class="aspect-[16/10] w-full rounded-[calc(var(--radius-lg)-4px)] object-cover"
        />
      </div>
      <Card>
        <Eyebrow>Specs</Eyebrow>
        <dl class="mt-4 grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-fg-muted">Year</dt><dd class="text-right text-fg">{d.year}</dd>
          <dt class="text-fg-muted">Body</dt><dd class="text-right text-fg">{d.bodyStyle}</dd>
          <dt class="text-fg-muted">Transmission</dt><dd class="text-right text-fg">{d.transmission}</dd>
          <dt class="text-fg-muted">Fuel</dt><dd class="text-right text-fg">{d.fuel}</dd>
          <dt class="text-fg-muted">Seats</dt><dd class="text-right text-fg">{d.seats}</dd>
          {d.minRentalDays && <><dt class="text-fg-muted">Min. rental</dt><dd class="text-right text-fg">{d.minRentalDays} days</dd></>}
        </dl>
        <WhatsAppButton
          client:visible
          template="rental.specific"
          vars={{ vehicle }}
          size="lg"
          variant="primary"
          className="mt-6 w-full"
        >
          Rent on WhatsApp
        </WhatsAppButton>
      </Card>
    </div>
  </Section>

  <Section bg="elev">
    <div class="prose prose-invert max-w-3xl text-fg-muted">
      <Content />
    </div>
    {d.features.length > 0 && (
      <div class="mt-10">
        <Eyebrow>Features</Eyebrow>
        <ul class="mt-4 grid grid-cols-1 gap-2 text-sm text-fg-muted md:grid-cols-2">
          {d.features.map((f) => <li>· {f}</li>)}
        </ul>
      </div>
    )}
  </Section>
</BaseLayout>
