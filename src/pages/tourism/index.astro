---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/primitives/Section.astro';
import Eyebrow from '../../components/primitives/Eyebrow.astro';
import Badge from '../../components/primitives/Badge.astro';
import { WhatsAppButton } from '../../components/cta/WhatsAppButton';
import { CallButton } from '../../components/cta/CallButton';
import { BentoGrid, BentoItem } from '../../components/fx/BentoGrid';
import { DISPLAY_PHONE_TOURISM } from '../../lib/wa';
---
<BaseLayout
  lane="tourism"
  title="Tourism"
  description="Taxi, rentals and excursions in Kissonerga, Cyprus. Airport transfers, safari trips, day trips. Published prices."
  ogImage="/og/og-tourism.jpg"
>
  <Section>
    <Eyebrow>Tourism</Eyebrow>
    <h1 class="mt-3 max-w-3xl font-display text-4xl leading-tight text-fg md:text-6xl text-balance">
      Everything you need for a memorable holiday.
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-fg-muted text-pretty">
      Airport to hotel. Rental for the week. Safari for the day. One phone
      number, one standard.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-4">
      <Badge>One number · {DISPLAY_PHONE_TOURISM}</Badge>
      <Badge variant="trust">English · Greek · Russian</Badge>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <WhatsAppButton client:visible template="contact.tourism" size="lg" variant="primary">
        Ask about tourism
      </WhatsAppButton>
      <CallButton client:visible lane="tourism" size="lg" variant="call" />
    </div>
  </Section>

  <Section bg="elev">
    <Eyebrow>What we do</Eyebrow>
    <BentoGrid client:visible className="mt-8">
      <BentoItem
        client:visible
        href="/tourism/taxi"
        eyebrow="Transfers"
        title="Taxi & airport pickup"
        description="Pafos, Larnaca, Limassol. Fixed quote before the trip. No meter surprises."
        className="md:col-span-2"
      />
      <BentoItem
        client:visible
        href="/tourism/rentals"
        eyebrow="Fleet"
        title="Car rentals"
        description="Daily and weekly rentals, ask for price. Delivery to hotel."
      />
      <BentoItem
        client:visible
        href="/tourism/excursions"
        eyebrow="Guided"
        title="Safari & day trips"
        description="Akamas 4x4, wine country, Troodos, sunset runs. Small groups."
        className="md:col-span-2"
      />
    </BentoGrid>
  </Section>
</BaseLayout>
