---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/primitives/Section.astro';
import Eyebrow from '../../../components/primitives/Eyebrow.astro';
import Card from '../../../components/primitives/Card.astro';
import Badge from '../../../components/primitives/Badge.astro';
import PriceTag from '../../../components/primitives/PriceTag.astro';
import { WhatsAppButton } from '../../../components/cta/WhatsAppButton';
import { touristTripSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  const all = await getCollection('excursions');
  return all.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'excursions'>;
}
const { entry } = Astro.props as Props;
const { Content } = await entry.render();
const d = entry.data;

const schema = touristTripSchema(entry, `/tourism/excursions/${entry.slug}`);

const langLabels: Record<'en' | 'el' | 'ru', string> = {
  en: 'English',
  el: 'Greek',
  ru: 'Russian',
};
---
<BaseLayout
  lane="tourism"
  title={d.title}
  description={`${d.type} excursion — ${d.durationHours}h, from €${d.startingFromEUR} ${d.perPersonOrGroup === 'per-person' ? 'per person' : 'per group'}.`}
  ogImage="/og/og-tourism.jpg"
  jsonLd={schema}
>
  <Section>
    <Eyebrow>Tourism · {d.type}</Eyebrow>
    <h1 class="mt-3 font-display text-4xl text-fg md:text-6xl text-balance">{d.title}</h1>
    <div class="mt-4 flex flex-wrap items-center gap-3">
      <PriceTag amount={d.startingFromEUR} period={d.perPersonOrGroup} />
      <Badge>{d.durationHours}h</Badge>
      <Badge>Max {d.maxGroupSize} pax</Badge>
      {d.pickupIncluded && <Badge variant="trust">Hotel pickup included</Badge>}
      {d.languagesOffered.map((l) => <Badge variant="muted">{langLabels[l]}</Badge>)}
    </div>

    <div class="mt-10 grid gap-8 md:grid-cols-[1.4fr_1fr]">
      <div class="overflow-hidden rounded-lg border border-gold/10 bg-bg-elev p-1">
        <Image
          src={d.heroImage}
          alt={d.title}
          width={1280}
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 60vw"
          format="webp"
          quality={78}
          class="aspect-[16/10] w-full rounded-[calc(var(--radius-lg)-4px)] object-cover"
        />
      </div>
      <Card>
        <Eyebrow>Book this trip</Eyebrow>
        <p class="mt-3 text-sm text-fg-muted">
          Tell us the date and group size. We'll confirm availability and the
          firm total — no hidden fees.
        </p>
        <WhatsAppButton
          client:visible
          template="excursion.specific"
          vars={{ title: d.title }}
          size="lg"
          variant="primary"
          className="mt-5 w-full"
        >
          Book on WhatsApp
        </WhatsAppButton>
      </Card>
    </div>
  </Section>

  {d.itinerary.length > 0 && (
    <Section bg="elev">
      <Eyebrow>Itinerary</Eyebrow>
      <ol class="mt-8 space-y-4">
        {d.itinerary.map((stop) => (
          <li class="flex gap-4 rounded-lg border border-gold/10 bg-bg p-4">
            <div class="font-display text-sm text-gold">{stop.time}</div>
            <div class="text-sm text-fg">{stop.stop}</div>
          </li>
        ))}
      </ol>
    </Section>
  )}

  <Section>
    <div class="prose prose-invert max-w-3xl text-fg-muted">
      <Content />
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {d.includes.length > 0 && (
        <Card>
          <div class="font-display text-lg text-gold">Included</div>
          <ul class="mt-3 space-y-1.5 text-sm text-fg-muted">
            {d.includes.map((f) => <li>· {f}</li>)}
          </ul>
        </Card>
      )}
      {d.excludes.length > 0 && (
        <Card>
          <div class="font-display text-lg text-gold">Not included</div>
          <ul class="mt-3 space-y-1.5 text-sm text-fg-muted">
            {d.excludes.map((f) => <li>· {f}</li>)}
          </ul>
        </Card>
      )}
    </div>
  </Section>
</BaseLayout>
