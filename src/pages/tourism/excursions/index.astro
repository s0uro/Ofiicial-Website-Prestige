---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/primitives/Section.astro';
import Container from '../../../components/primitives/Container.astro';
import Eyebrow from '../../../components/primitives/Eyebrow.astro';
import Card from '../../../components/primitives/Card.astro';
import Badge from '../../../components/primitives/Badge.astro';
import PriceTag from '../../../components/primitives/PriceTag.astro';
import { WhatsAppButton } from '../../../components/cta/WhatsAppButton';
import { Meteors } from '../../../components/fx/Meteors';

const excursions = (await getCollection('excursions')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  lane="tourism"
  title="Excursions and Safari Tours in Cyprus"
  description="Guided excursions and safari tours in Cyprus. Akamas 4x4, wine country, Troodos day trips and sunset tours. Small groups, hotel pickup included."
  ogImage="/og/og-tourism.jpg"
>
  <section class="relative overflow-hidden border-b border-gold/10 py-24 md:py-32">
    <Meteors client:visible number={14} />
    <Container class="relative z-10">
      <Eyebrow>Tourism · Guided</Eyebrow>
      <h1 class="mt-3 max-w-3xl font-display text-4xl text-fg md:text-6xl text-balance">
        Guided Excursions and Safari Tours in Pafos, Cyprus.
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-fg-muted text-pretty">
        Small groups. English, Greek or Russian guides. Hotel pickup included.
        Per-person rates published — no "contact for price".
      </p>
      <div class="mt-8">
        <WhatsAppButton client:visible template="excursion.general" size="lg" variant="primary">
          Ask about excursions
        </WhatsAppButton>
      </div>
    </Container>
  </section>

  <Section>
    <Eyebrow>Current roster</Eyebrow>
    {excursions.length === 0 ? (
      <Card class="mt-8">
        <div class="font-display text-xl text-fg">Roster updates seasonally</div>
        <p class="mt-2 text-sm text-fg-muted">
          We're between seasons. Tell us what you'd like to see — we usually
          have something that fits.
        </p>
        <WhatsAppButton client:visible template="excursion.general" size="sm" variant="primary" className="mt-4">
          Ask what's running
        </WhatsAppButton>
      </Card>
    ) : (
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {excursions.map((ex) => (
          <a href={`/tourism/excursions/${ex.slug}`} class="block">
            <Card class="transition-all hover:-translate-y-0.5 hover:border-gold/30">
              <Image
                src={ex.data.heroImage}
                alt={ex.data.title}
                width={640}
                widths={[320, 640]}
                sizes="(max-width: 768px) 100vw, 33vw"
                format="webp"
                quality={75}
                loading="lazy"
                class="aspect-[16/10] w-full rounded border border-gold/10 object-cover"
              />
              <div class="mt-4 flex items-start justify-between gap-2">
                <div>
                  <Badge variant="muted">{ex.data.type}</Badge>
                  <div class="mt-2 font-display text-xl text-fg">{ex.data.title}</div>
                  <p class="mt-1 text-sm text-fg-muted">{ex.data.durationHours}h · max {ex.data.maxGroupSize} pax</p>
                </div>
                <PriceTag amount={ex.data.startingFromEUR} period={ex.data.perPersonOrGroup} />
              </div>
            </Card>
          </a>
        ))}
      </div>
    )}
  </Section>
</BaseLayout>
