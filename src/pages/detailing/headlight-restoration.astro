---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/primitives/Section.astro';
import Container from '../../components/primitives/Container.astro';
import Eyebrow from '../../components/primitives/Eyebrow.astro';
import Badge from '../../components/primitives/Badge.astro';
import PriceTag from '../../components/primitives/PriceTag.astro';
import Card from '../../components/primitives/Card.astro';
import { WhatsAppButton } from '../../components/cta/WhatsAppButton';
import { AuroraBackground } from '../../components/fx/AuroraBackground';
import TextReveal from '../../components/fx/TextReveal.astro';
import { MagneticButton } from '../../components/fx/MagneticButton';
import { autoRepairSchema, breadcrumbSchema, faqPageSchema } from '../../lib/schema';

const schema = autoRepairSchema({
  name: 'S.Prestige — Headlight restoration',
  description:
    'Cypriot UV and salt yellow headlights in 18–24 months. We restore them in about an hour, from €45 per pair.',
  url: '/detailing/headlight-restoration',
  priceFromEUR: 45,
});
const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Detailing', url: '/detailing' },
  { name: 'Headlight restoration', url: '/detailing/headlight-restoration' },
]);

// TODO: real starting-from from client
const startingFrom = 45;

const steps = [
  { n: '01', title: 'Inspect', body: 'Depth of yellowing, cracking, pitting. 5-minute assessment.' },
  { n: '02', title: 'Wet-sand', body: 'Progressively finer grits remove UV-oxidised plastic.' },
  { n: '03', title: 'Polish', body: 'Machine polish brings optical clarity back.' },
  { n: '04', title: 'UV seal', body: '2K clear coat seals the lens for 18–24 months.' },
];

const faq = [
  { q: 'How long does it take?', a: 'About one hour per pair for a standard car. Book a morning slot and the car is ready at lunch.' },
  { q: 'How long does the result last?', a: 'With our 2K UV clear coat, 18–24 months in Cypriot conditions. We publish that number because we stand behind it.' },
  { q: 'Can you do it at home?', a: 'We work at the Kissonerga bay — the wet-sand stage needs a controlled environment.' },
  { q: 'What if the plastic is cracked?', a: 'Deep cracks mean new housings. We will tell you before starting — no surprise at pickup.' },
];
const faqSchema = faqPageSchema(faq);
---
<BaseLayout
  lane="auto"
  title="Headlight Restoration in Pafos, Cyprus"
  description="Cypriot UV and salt turn headlights yellow in 18 to 24 months. Headlight restoration in Kissonerga, Pafos from €45. Back to clear in about an hour."
  ogImage="/og/og-detailing.jpg"
  jsonLd={[schema, breadcrumbs, faqSchema]}
>
  <AuroraBackground className="relative">
    <Container class="relative z-10 py-24 md:py-32">
      <Eyebrow>Auto · Flagship</Eyebrow>
      <TextReveal
        as="h1"
        text="Headlight Restoration in Kissonerga, Pafos. Back to clear in about an hour."
        className="mt-4 max-w-4xl font-display text-4xl font-semibold leading-[1.05] md:text-7xl gold-gradient-text text-balance"
      />
      <p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty">
        UV and salt air turn Cypriot headlights hazy in 18–24 months. It costs
        you light at night and a visible age-tell by day. We fix both — in
        about an hour.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <PriceTag amount={startingFrom} period="total" />
        <Badge>Per pair</Badge>
      </div>
      <div class="mt-8">
        <MagneticButton client:idle>
          <WhatsAppButton
            template="detailing.headlight"
            size="lg"
            variant="primary"
          >
            Get a slot
          </WhatsAppButton>
        </MagneticButton>
      </div>
    </Container>
  </AuroraBackground>

  <Section>
    <Eyebrow>The process</Eyebrow>
    <h2 class="mt-3 font-display text-3xl text-fg md:text-5xl">Four steps. Same every time.</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-4">
      {steps.map((s) => (
        <Card>
          <div class="font-display text-2xl text-gold">{s.n}</div>
          <div class="mt-2 font-display text-lg text-fg">{s.title}</div>
          <p class="mt-2 text-sm text-fg-muted">{s.body}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section bg="elev">
    <Eyebrow>FAQ</Eyebrow>
    <h2 class="mt-3 font-display text-3xl text-fg md:text-5xl">Straight answers.</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {faq.map((item) => (
        <Card>
          <div class="font-display text-lg text-fg">{item.q}</div>
          <p class="mt-2 text-sm leading-relaxed text-fg-muted">{item.a}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section>
    <div class="flex flex-wrap items-center justify-between gap-6">
      <div>
        <Eyebrow>Ready?</Eyebrow>
        <h2 class="mt-3 font-display text-3xl text-fg md:text-4xl">Morning slots go first.</h2>
      </div>
      <WhatsAppButton template="detailing.headlight" size="lg" variant="primary">
        Book on WhatsApp
      </WhatsAppButton>
    </div>
  </Section>
</BaseLayout>
