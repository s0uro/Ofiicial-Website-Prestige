---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/primitives/Section.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import { WhatsAppButton } from '../components/cta/WhatsAppButton';
---
<BaseLayout
  lane="shared"
  title="Not found"
  description="This page does not exist."
  noindex
>
  <Section spacing="loose">
    <Eyebrow>404</Eyebrow>
    <h1 class="mt-3 font-display text-5xl text-fg md:text-7xl gold-gradient-text">
      Wrong turn.
    </h1>
    <p class="mt-4 max-w-xl text-fg-muted">
      This page does not exist, or it was renamed. Head home, or ask us on
      WhatsApp — we'll point you at the right lane.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class="inline-flex h-11 items-center rounded-md bg-gold px-5 font-medium text-bg transition-colors hover:bg-gold-soft">
        Back home
      </a>
      <WhatsAppButton client:visible template="contact.auto" variant="secondary">
        Ask on WhatsApp
      </WhatsAppButton>
    </div>
  </Section>
</BaseLayout>
