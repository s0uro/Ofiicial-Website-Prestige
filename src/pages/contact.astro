---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/primitives/Section.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import Card from '../components/primitives/Card.astro';
import { DIMITRIS_LINES, ALEXANDRA_LINE } from '../lib/wa';
import { contactPageSchema } from '../lib/schema';

const mapUrl = 'https://www.google.com/maps?q=S.PRESTIGE+SERVICES+Kissonerga+Cyprus&z=17&output=embed';

const autoMessage = encodeURIComponent('Hi S.Prestige — I have a question.');
const rentalsMessage = encodeURIComponent('Hi S.Prestige — I have a rentals question.');

const iconBtn =
  'inline-flex h-9 w-9 items-center justify-center rounded-full border border-gold/30 text-gold transition-colors hover:border-gold hover:bg-gold/10';
---
<BaseLayout
  lane="shared"
  title="Contact"
  description="Phone numbers, hours and location for S.Prestige Services, Kissonerga, Cyprus."
  jsonLd={contactPageSchema()}
>
  <Section>
    <Eyebrow>Contact</Eyebrow>
    <h1 class="mt-3 font-display text-4xl text-fg md:text-6xl text-balance">
      Two desks. One address.
    </h1>
    <p class="mt-4 max-w-xl text-fg-muted">
      Auto runs on two lines so something always answers. Rentals has its own
      desk for booking, pickup and returns.
    </p>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <Card>
        <Eyebrow>Auto</Eyebrow>
        <p class="mt-2 text-sm text-fg-muted">
          Detailing · Mechanical · Recovery · Buy & sell · Transfers
        </p>

        <div class="mt-6">
          <div class="font-display text-lg text-fg">Dimitris</div>
          <ul class="mt-3 divide-y divide-gold/10 border-y border-gold/10">
            {DIMITRIS_LINES.map((line) => (
              <li class="flex items-center justify-between gap-3 py-3">
                <a
                  href={`tel:${line.tel}`}
                  class="font-display text-base text-gold transition-colors hover:text-gold-soft md:text-lg"
                >
                  {line.display}
                </a>
                <div class="flex items-center gap-2">
                  <a
                    href={`https://wa.me/${line.wa}?text=${autoMessage}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={iconBtn}
                    aria-label={`WhatsApp Dimitris on ${line.display}`}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                    </svg>
                  </a>
                  <a
                    href={`tel:${line.tel}`}
                    class={iconBtn}
                    aria-label={`Call Dimitris on ${line.display}`}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  </a>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </Card>

      <Card>
        <Eyebrow>Rentals</Eyebrow>
        <p class="mt-2 text-sm text-fg-muted">
          Daily and weekly rentals · Airport pickup · Insurance included
        </p>

        <div class="mt-6">
          <div class="font-display text-lg text-fg">Alexandra</div>
          <ul class="mt-3 divide-y divide-gold/10 border-y border-gold/10">
            <li class="flex items-center justify-between gap-3 py-3">
              <a
                href={`tel:${ALEXANDRA_LINE.tel}`}
                class="font-display text-base text-gold transition-colors hover:text-gold-soft md:text-lg"
              >
                {ALEXANDRA_LINE.display}
              </a>
              <div class="flex items-center gap-2">
                <a
                  href={`https://wa.me/${ALEXANDRA_LINE.wa}?text=${rentalsMessage}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={iconBtn}
                  aria-label={`WhatsApp Alexandra on ${ALEXANDRA_LINE.display}`}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                  </svg>
                </a>
                <a
                  href={`tel:${ALEXANDRA_LINE.tel}`}
                  class={iconBtn}
                  aria-label={`Call Alexandra on ${ALEXANDRA_LINE.display}`}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </a>
              </div>
            </li>
          </ul>
        </div>
      </Card>
    </div>
  </Section>

  <Section bg="elev">
    <div class="grid gap-8 md:grid-cols-[1fr_1.2fr]">
      <div>
        <Eyebrow>Visit</Eyebrow>
        <address class="mt-3 not-italic text-fg">
          <div class="font-display text-xl">Eustathios Plaza, Leoforos Chrisoneras, Kat.5</div>
          <div class="mt-1 text-fg-muted">Kissonerga, Pafos 8574, Cyprus</div>
        </address>
        <div class="mt-6">
          <Eyebrow>Hours</Eyebrow>
          <dl class="mt-3 grid max-w-xs grid-cols-2 gap-y-1 text-sm text-fg-muted">
            <dt>Mon–Sat</dt><dd class="text-right text-fg">08:00–18:00</dd>
            <dt>Sunday</dt><dd class="text-right text-fg">Closed</dd>
          </dl>
        </div>
      </div>
      <div class="rounded-lg border border-gold/10 bg-bg p-1">
        <iframe
          title="S.Prestige Services — map"
          src={mapUrl}
          loading="lazy"
          class="h-[360px] w-full rounded-[calc(var(--radius-lg)-4px)]"
          style="border: 0;"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
        />
      </div>
    </div>
  </Section>
</BaseLayout>
