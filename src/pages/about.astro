---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/primitives/Section.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import Card from '../components/primitives/Card.astro';
import { WhatsAppButton } from '../components/cta/WhatsAppButton';
import { aboutPageSchema, personSchema } from '../lib/schema';

const facts = [
  { k: 'Founded', v: 'Kissonerga, 2017' },
  { k: 'Specialty', v: 'Detailing + tourism under one roof' },
  { k: 'Languages', v: 'English · Greek · Russian' },
  { k: 'Payment', v: 'Cash, card, bank transfer' },
];

const persons = [
  personSchema({
    id: '/#dimitris',
    name: 'Dimitris',
    jobTitle: 'Head of Auto Services — Detailing, Mechanical, Recovery & Buy/Sell',
    telephone: '+35796471717',
    knowsLanguage: ['en', 'el'],
  }),
  personSchema({
    id: '/#alexandra',
    name: 'Alexandra',
    jobTitle: 'Head of Tourism — Car Rentals & Transfers',
    telephone: '+35796828299',
    knowsLanguage: ['en', 'el', 'ru'],
  }),
];
---
<BaseLayout
  lane="shared"
  title="About S.Prestige Services — Kissonerga, Paphos"
  description="S.Prestige Services: established in Kissonerga, Paphos in 2017. Car detailing, rentals, mechanical work, recovery and airport transfers. English, Greek & Russian spoken."
  jsonLd={[aboutPageSchema(), ...persons]}
>
  <Section>
    <Eyebrow>About</Eyebrow>
    <h1 class="mt-3 max-w-3xl font-display text-4xl leading-tight text-fg md:text-6xl text-balance">
      Two services. One bar. Quiet confidence.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-fg-muted text-pretty">
      We started on the detailing bay in Kissonerga. Tourists kept asking for
      a ride after their car came back clean — so we put the second lane on the
      sign. Same phone-number discipline. Same published prices. No hidden
      charges at pickup.
    </p>
  </Section>

  <Section bg="elev">
    <div class="grid gap-4 md:grid-cols-2">
      {facts.map((f) => (
        <Card>
          <div class="text-[10px] uppercase tracking-[0.2em] text-gold">{f.k}</div>
          <div class="mt-2 font-display text-xl text-fg">{f.v}</div>
        </Card>
      ))}
    </div>
  </Section>

  <Section>
    <Eyebrow>Talk to us</Eyebrow>
    <h2 class="mt-3 font-display text-3xl text-fg md:text-5xl">Which lane?</h2>
    <div class="mt-8 flex flex-wrap gap-3">
      <WhatsAppButton client:visible template="contact.auto" size="lg" variant="primary">
        Auto
      </WhatsAppButton>
      <WhatsAppButton client:visible template="contact.tourism" size="lg" variant="secondary">
        Tourism
      </WhatsAppButton>
    </div>
  </Section>
</BaseLayout>
