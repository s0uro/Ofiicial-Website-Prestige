---
import { cn } from '../../lib/cn';

interface Props {
  text: string;
  className?: string;
  as?: 'h1' | 'h2' | 'h3' | 'p';
  /** Initial delay before line 1 starts (seconds). */
  delay?: number;
  /** Gap between word reveals within the same line (seconds). */
  stagger?: number;
  /** Gap between successive lines (seconds). */
  lineStagger?: number;
  /** Each word's animation duration (seconds). */
  duration?: number;
}

const {
  text,
  className,
  as = 'h2',
  delay = 0,
  stagger = 0.05,
  lineStagger = 0.65,
  duration = 0.5,
} = Astro.props as Props;

const lines = text.split('\n');
const multiLine = lines.length > 1;
const Tag = as;
---
<Tag class={cn(className)} aria-label={text.replace(/\n/g, ' ')}>
  {lines.map((line, li) => (
    <span class={cn('block', multiLine && 'whitespace-nowrap')}>
      {line.split(' ').map((word, wi) => (
        <span
          aria-hidden="true"
          class="tr-word mr-[0.25em] inline-block whitespace-nowrap"
          style={`animation-delay: ${delay + li * lineStagger + wi * stagger}s; animation-duration: ${duration}s;`}
        >
          {word}
        </span>
      ))}
    </span>
  ))}
</Tag>

<style>
  .tr-word {
    opacity: 0;
    transform: translateY(0.5em);
    animation-name: text-reveal-word;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: forwards;
  }

  @keyframes text-reveal-word {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tr-word {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
