---
import { cn } from '../../lib/cn';

export interface Props {
  class?: string;
  padded?: boolean;
  bordered?: boolean;
  as?: 'div' | 'article' | 'section' | 'li';
}

const {
  class: className,
  padded = true,
  bordered = true,
  as: Tag = 'div',
} = Astro.props;
---
<Tag
  class={cn(
    'relative overflow-hidden rounded-xl bg-bg-elev shadow-card transition-[border-color,box-shadow] duration-300 ease-out-expo',
    bordered && 'border border-gold/10 hover:border-gold/25 hover:shadow-card-hover',
    padded && 'p-6 md:p-7',
    className,
  )}
>
  <slot />
</Tag>
