---
import Container from '../primitives/Container.astro';
import {
  DISPLAY_PHONE_AUTO,
  DISPLAY_PHONE_AUTO_2,
  DISPLAY_PHONE_TOURISM,
  TEL_AUTO,
  TEL_AUTO_2,
  TEL_TOURISM,
} from '../../lib/wa';

const year = new Date().getFullYear();
---
<footer class="relative mt-24 bg-bg-elev" aria-labelledby="footer-brand">
  <div class="h-px w-full bg-gradient-to-r from-transparent via-gold/30 to-transparent" aria-hidden="true" />
  <Container class="py-12 md:py-16">
    <div class="max-w-3xl">
      <div id="footer-brand" class="flex items-center gap-2.5 font-display text-xl text-fg">
        <img
          src="/logo-mark.png"
          alt=""
          width="40"
          height="40"
          class="h-9 w-9"
          aria-hidden="true"
        />
        <span><span class="text-gold">S.</span>Prestige Services</span>
      </div>
      <p class="mt-3 text-sm text-fg-muted">
        Eustathios Plaza, Kissonerga, Pafos 8574
      </p>
      <p class="mt-1 text-sm text-fg-muted">
        Mon–Sat 08:00–18:00
      </p>

      <dl class="mt-8 grid gap-3 text-sm sm:grid-cols-[auto_1fr_auto] sm:items-baseline sm:gap-x-8 sm:gap-y-3">
        <dt class="text-[11px] uppercase tracking-[0.2em] text-gold">Auto</dt>
        <dd class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <a href={`tel:${TEL_AUTO}`} class="font-display text-base text-fg transition-colors hover:text-gold">
            {DISPLAY_PHONE_AUTO}
          </a>
          <span class="text-fg-muted/50">·</span>
          <a href={`tel:${TEL_AUTO_2}`} class="font-display text-base text-fg transition-colors hover:text-gold">
            {DISPLAY_PHONE_AUTO_2}
          </a>
        </dd>
        <dd class="text-[11px] uppercase tracking-[0.2em] text-fg-muted">Dimitris</dd>

        <dt class="text-[11px] uppercase tracking-[0.2em] text-gold">Rentals</dt>
        <dd>
          <a href={`tel:${TEL_TOURISM}`} class="font-display text-base text-fg transition-colors hover:text-gold">
            {DISPLAY_PHONE_TOURISM}
          </a>
        </dd>
        <dd class="text-[11px] uppercase tracking-[0.2em] text-fg-muted">Alexandra</dd>
      </dl>
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-2">
      <a
        href="https://www.instagram.com/prestige_detailing.cy/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="S.Prestige on Instagram"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gold/20 bg-bg text-fg-muted transition-all duration-200 hover:border-gold/50 hover:bg-gold/8 hover:text-gold hover:shadow-glow-sm"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" />
        </svg>
      </a>
      <a
        href="https://www.facebook.com/people/Prestige-Detailing/100076279789752/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="S.Prestige on Facebook"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-gold/20 bg-bg text-fg-muted transition-all duration-200 hover:border-gold/50 hover:bg-gold/8 hover:text-gold hover:shadow-glow-sm"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path d="M13.5 21v-7.5h2.5l.4-3h-2.9V8.6c0-.87.24-1.46 1.49-1.46H17V4.4c-.27-.04-1.23-.12-2.34-.12-2.32 0-3.91 1.42-3.91 4.02v2.25H8v3h2.75V21h2.75Z" />
        </svg>
      </a>
    </div>

    <div class="mt-6 flex flex-wrap items-center justify-between gap-x-6 gap-y-3 border-t border-gold/8 pt-6 text-xs text-fg-muted/70">
      <span>© {year} S.Prestige Services</span>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/about" class="transition-colors hover:text-fg">About</a>
        <a href="/contact" class="transition-colors hover:text-fg">Contact</a>
        <a href="/legal/privacy" class="transition-colors hover:text-fg">Privacy</a>
        <a href="/legal/terms" class="transition-colors hover:text-fg">Terms</a>
      </div>
    </div>
  </Container>
</footer>
