---
import Container from '../primitives/Container.astro';
import MobileMenu from './MobileMenu.tsx';
import EmergencyButton from '../cta/EmergencyButton.astro';
import LanguageSwitcher from './LanguageSwitcher.tsx';

export interface Props {
  lane?: 'auto' | 'tourism' | 'shared';
}

const { lane = 'shared' } = Astro.props;

const navItems = [
  { label: 'Buy & Sell', href: '/buy-sell', key: 'buySell' },
  { label: 'Rentals', href: '/tourism/rentals', key: 'rentals' },
  { label: 'Detailing', href: '/detailing', key: 'detailing' },
  { label: 'Mechanical', href: '/mechanical', key: 'mechanical' },
  { label: 'Recovery', href: '/recovery', key: 'recovery' },
  { label: 'Transfers', href: '/tourism/taxi', key: 'transfers' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];

const pathname = Astro.url.pathname;
---
<header
  data-lane={lane}
  class="sticky top-0 z-30 border-b border-gold/10 bg-bg/85 backdrop-blur-md supports-[backdrop-filter]:bg-bg/65"
>
  <Container class="flex h-16 items-center justify-between gap-4 md:h-[4.5rem]">
    <a
      href="/"
      class="group flex items-center gap-2.5 font-display text-lg font-semibold tracking-wide text-fg transition-opacity hover:opacity-90 md:text-xl"
      aria-label="S.Prestige Services — home"
    >
      <img
        src="/logo-mark.png"
        alt=""
        width="40"
        height="40"
        class="h-7 w-7 transition-transform duration-300 group-hover:scale-105 md:h-9 md:w-9"
        aria-hidden="true"
      />
      <span><span class="text-gold">S.</span>Prestige</span>
    </a>

    <nav class="hidden items-center gap-7 text-sm text-fg-muted lg:flex" aria-label="Primary">
      {navItems.map((item) => {
        const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href + '/'));
        return (
          <a
            href={item.href}
            class:list={[
              'group relative whitespace-nowrap transition-colors duration-200 hover:text-fg',
              active ? 'text-fg' : 'text-fg-muted',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            <span data-nav-key={item.key}>{item.label}</span>
            <span
              class:list={[
                'absolute inset-x-0 -bottom-px h-px origin-left bg-gradient-to-r from-gold to-gold/50 transition-transform duration-300 ease-out-expo',
                active ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100',
              ]}
              aria-hidden="true"
            />
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <div class="hidden lg:flex">
        <LanguageSwitcher client:load />
      </div>
      <div class="hidden lg:block">
        <EmergencyButton variant="full" />
      </div>
      <div class="lg:hidden">
        <EmergencyButton variant="compact" />
      </div>
      <MobileMenu client:load items={navItems} />
    </div>
  </Container>
</header>

<script>
  import { getLang, ui } from '../../lib/i18n';

  function applyLang(lang: string) {
    const dict = ui[lang as keyof typeof ui];
    if (!dict) return;

    document.querySelectorAll<HTMLElement>('[data-nav-key]').forEach((el) => {
      const key = el.dataset.navKey as keyof typeof dict.nav;
      if (dict.nav[key]) el.textContent = dict.nav[key];
    });

    const emEl = document.querySelector<HTMLElement>('[data-t-emergency]');
    if (emEl) emEl.textContent = dict.emergency;
  }

  applyLang(getLang());

  window.addEventListener('sprestige:lang', (e) => {
    applyLang((e as CustomEvent<string>).detail);
  });
</script>
